# Self-host stack environment. Copy to .env and edit.
#   cp .env.example .env

# ── Convex backend ──────────────────────────────────────────
# A short instance name and a long random secret for the self-hosted backend.
# Generate a secret with: openssl rand -hex 32
CONVEX_INSTANCE_NAME=ados-selfhost
CONVEX_INSTANCE_SECRET=replace-with-openssl-rand-hex-32

# The origins the backend advertises. On a single host reachable at <host>,
# point these at the published ports. Use your LAN IP or hostname for <host>.
CONVEX_CLOUD_ORIGIN=http://localhost:3210
CONVEX_SITE_ORIGIN=http://localhost:3211

# ── Port wiring (critical) ──────────────────────────────────
# GCS browser client -> Convex CLIENT-API origin (:3210).
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210

# MQTT bridge + agent -> Convex SITE / HTTP-actions origin (:3211).
# The bridge POSTs to ${CONVEX_URL}/agent/status.
CONVEX_URL=http://localhost:3211

# ── MQTT ────────────────────────────────────────────────────
MQTT_USERNAME=ados
MQTT_PASSWORD=replace-with-your-mqtt-password

# ── Video relay ─────────────────────────────────────────────
# {deviceId} is substituted at runtime with the drone's device id.
RTSP_URL_PATTERN=rtsp://host.docker.internal:8554/{deviceId}
